# --- Secrets & credentials ---
# Holds your real Wazuh/Indexer passwords — never goes to GitHub
.env

# Holds your real lab IPs — commit config.example.py instead, with placeholders
config.py

# Authentication tokens generated by the Wazuh API
token.txt

# SSH keys used to access your lab VMs
*.pem
*.key
soc_key
soc_key.pub

# Wazuh/OpenSearch TLS certificates — tied to your specific lab, not reusable, and sensitive
root-ca.pem
wazuh-server.pem
wazuh-server-key.pem

# --- Local databases ---
# SQLite files contain real incident/alert data from your runs, not source code
*.db
*.db-shm
*.db-wal
*.db-journal
*.sqlite
*.sqlite3

# --- Python ---
# Compiled bytecode — regenerated automatically, no reason to track it
__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual environments — huge, machine-specific, everyone rebuilds their own
venv/
.venv/
env/

# Packaging/build output
dist/
build/
*.egg-info/

# --- Streamlit ---
# Local Streamlit cache/config, not part of the app itself
.streamlit/

# --- Logs & temp files ---
*.log
*.tmp
*.bak
hydra.restore

# --- IDE-specific files ---
# Personal editor settings — not relevant to anyone else cloning the repo
.vscode/
.idea/

# Jupyter checkpoint files
.ipynb_checkpoints/

# --- OS-specific junk ---
.DS_Store
Thumbs.db
